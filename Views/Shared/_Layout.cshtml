<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Velora</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS v3 Local (fully configurable) -->
    <script src="~/js/tailwind.js"></script>
    <script>
        tailwind.config = {
          theme: {
            extend: {
              colors: {
                'warm-black': '#0a0908',
                'warm-dark': '#12100e',
                'warm-card': '#1c1a18',
                'warm-gray': '#2e2a27',
                'gold-light': '#b3f0ff',
                'gold': '#00e5a3',
                'gold-dark': '#00a876',
                'amber-glow': '#00b5ff',
                'terracotta': '#8a5cf5',
                'clay': '#5a2eee',
                'earth-sand': '#e7e5e4',
                'earth-mud': '#78716c',
              },
              fontFamily: {
                sans: ['Inter', 'sans-serif'],
                outfit: ['Outfit', 'sans-serif'],
                playfair: ['Playfair Display', 'serif'],
              },
              animation: {
                'spin-slow': 'spin 15s linear infinite',
              }
            }
          }
        }
    </script>

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- Lucide Icons Library Local -->
    <script src="~/js/lucide.js"></script>
</head>
<body class="bg-warm-black text-earth-sand font-sans overflow-x-hidden min-h-screen">
    <div class="relative min-h-screen flex flex-col justify-between overflow-x-hidden">
        @RenderBody()
    </div>

    <!-- Lucide icons replacement trigger -->
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            lucide.createIcons();
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
