<section id="view-rooms" class="view-panel hidden w-full max-w-5xl mx-auto px-4 h-[calc(100vh-140px)] md:h-[calc(100vh-110px)] grid grid-cols-1 md:grid-cols-12 gap-6">
    <!-- Left Side Stage -->
    <div class="md:col-span-7 glass-panel rounded-3xl border border-white/5 p-5 flex flex-col h-full overflow-hidden text-left" id="live-rooms-main-card"></div>

    <!-- Right Side Stage Chat -->
    <div class="md:col-span-5 glass-panel rounded-3xl border border-white/5 flex flex-col h-full overflow-hidden text-left" id="live-rooms-chat-pane">
        <div class="p-4 border-b border-white/5 flex items-center gap-2">
            <i data-lucide="message-square" class="w-4 h-4 text-amber-glow"></i>
            <h3 class="text-xs font-bold font-outfit uppercase tracking-widest text-stone-400">Stage Chat</h3>
        </div>
        <div id="room-chat-messages" class="flex-grow p-4 overflow-y-auto space-y-3.5"></div>
        <div class="p-4 border-t border-white/5 bg-black/20 flex gap-2">
            <input type="text" id="room-chat-input" placeholder="Say something..." onkeypress="handleRoomChatKeyPress(event)" class="flex-grow bg-white/[0.02] border border-white/5 rounded-xl px-4 py-2.5 text-stone-200 placeholder-stone-600 text-xs focus:outline-none">
            <button onclick="sendRoomChatMessage()" class="p-2.5 bg-gradient-to-r from-amber-glow to-terracotta hover:opacity-90 rounded-xl text-stone-950 transition cursor-pointer">
                <i data-lucide="send" class="w-4 h-4"></i>
            </button>
        </div>
    </div>
</section>
