<div id="match-modal-overlay" class="hidden fixed inset-0 z-50 flex items-center justify-center p-6 bg-black/85 backdrop-blur-md">
    <div class="w-full max-w-md glass-panel rounded-3xl p-8 border border-white/10 text-center relative overflow-hidden shadow-2xl">
        <div class="absolute top-1/4 left-1/4 w-80 h-80 bg-amber-glow/20 rounded-full filter blur-3xl opacity-20 pointer-events-none animate-pulse"></div>
        
        <div class="flex justify-center gap-1.5 text-amber-glow animate-sparkle mb-4">
            <i data-lucide="sparkles" class="w-5 h-5 fill-amber-glow"></i>
            <span class="text-xs font-bold font-outfit uppercase tracking-widest">Chemistry Synergy Configured</span>
            <i data-lucide="sparkles" class="w-5 h-5 fill-amber-glow"></i>
        </div>
        
        <h2 class="text-3xl font-playfair font-bold text-white mb-2">It's a Connection!</h2>
        <p class="text-xs text-stone-400 max-w-xs mx-auto mb-8">Your communication dial metrics match each other perfectly.</p>
        
        <div class="flex items-center justify-center gap-6 mb-8">
            <div class="relative">
                <div class="absolute -inset-2 rounded-2xl bg-amber-glow/10 border border-amber-glow/20 animate-pulse"></div>
                <img id="match-modal-user-avatar" src="" class="w-20 h-20 rounded-2xl object-cover border-2 border-white/20 relative z-10" alt="You">
                <span class="absolute -bottom-2 right-2 px-2 py-0.5 rounded bg-amber-glow text-warm-black font-mono text-[9px] font-bold z-20 shadow-md">YOU</span>
            </div>
            
            <i data-lucide="arrow-left-right" class="w-6 h-6 text-stone-600 animate-pulse"></i>

            <div class="relative">
                <div class="absolute -inset-2 rounded-2xl bg-terracotta/10 border border-terracotta/20 animate-pulse"></div>
                <img id="match-modal-match-avatar" src="" class="w-20 h-20 rounded-2xl object-cover border-2 border-white/20 relative z-10" alt="Match">
                <span id="match-modal-match-name-badge" class="absolute -bottom-2 right-2 px-2 py-0.5 rounded bg-terracotta text-white font-mono text-[9px] font-bold z-20 shadow-md">MATCH</span>
            </div>
        </div>

        <div class="space-y-3">
            <button id="match-modal-chat-btn" class="w-full py-3.5 text-xs font-bold font-outfit uppercase tracking-wider rounded-xl bg-gradient-to-r from-amber-glow to-terracotta text-warm-black shadow-lg">
                Initiate Direct Link
            </button>
            <button onclick="closeMatchModal()" class="w-full py-3.5 text-xs font-semibold font-outfit uppercase tracking-wider rounded-xl border border-white/10 hover:bg-white/5 text-stone-400 hover:text-white transition">
                Keep Calibrating
            </button>
        </div>
    </div>
</div>
